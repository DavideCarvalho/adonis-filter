{
  "name": "@adonis-agora/filter",
  "version": "0.4.0",
  "description": "Server-side query filtering/sorting/pagination for AdonisJS — Spatie-style input, a Lucid adapter, and field allow-listing. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-filter.git",
    "directory": "packages/core"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js",
      "default": "./dist/src/testing.js"
    },
    "./commands": {
      "types": "./dist/commands/main.d.ts",
      "import": "./dist/commands/main.js",
      "default": "./dist/commands/main.js"
    },
    "./filter_provider": {
      "types": "./dist/providers/filter_provider.d.ts",
      "import": "./dist/providers/filter_provider.js",
      "default": "./dist/providers/filter_provider.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typetest.json"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/core": {
      "optional": true
    },
    "@adonisjs/lucid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "22.4.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": ["adonisjs", "adonis", "filter", "lucid", "query", "spatie", "pagination", "agora"]
}
