{
  "name": "@agora/filter-client",
  "version": "0.1.0",
  "description": "Client-side query builder for @agora/filter — build filter query strings, with optional TanStack Table state sync.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-filter.git",
    "directory": "packages/client"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tanstack": {
      "types": "./dist/tanstack.d.ts",
      "import": "./dist/tanstack.js",
      "default": "./dist/tanstack.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:types": "tsc -p tsconfig.typecheck.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typecheck.json"
  },
  "peerDependencies": {
    "@tanstack/table-core": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/table-core": { "optional": true }
  },
  "devDependencies": {
    "@tanstack/table-core": "^8.20.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=20.6.0" },
  "keywords": ["adonisjs", "adonis", "filter", "query", "client", "builder", "agora"]
}
